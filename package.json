{
  "name": "@qlever-llc/trellis-data-manager",
  "version": "0.3.7",
  "description": "A microservice for managing trellis master data elements.",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "src/**/*",
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "start": "node ${INSPECT:-} --enable-source-maps dist/index.js",
    "test": "yarn build test && c8 ava -T 60m -svc 1 --no-worker-threads",
    "dev:test": "tsc -b --watch ./test",
    "test:debug": "ava -T 60m -svc 1 --no-worker-threads",
    "lint": "biome check"
  },
  "ava": {
    "failFast": false,
    "files": [
      "**/*.test.ts"
    ],
    "typescript": {
      "extensions": [
        "ts"
      ],
      "rewritePaths": {
        "src/": "dist/",
        "test/": ".test/"
      },
      "compile": false
    }
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true,
    "src": "src",
    "exclude": [
      "*.d.ts",
      ".pnp.*",
      ".test"
    ]
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@elastic/elasticsearch": "^9.4.0",
    "@oada/client": "^6.0.1",
    "@oada/jobs": "^5.0.0",
    "@oada/lib-config": "^4.0.0",
    "@oada/lib-prom": "^4.0.2",
    "@oada/list-lib": "^4.3.0",
    "@oada/pino-debug": "^4.0.1",
    "@oada/types": "^4.1.2",
    "convict-format-with-moment": "^6.2.0",
    "debug": "^4.4.3",
    "es-main": "^1.4.0",
    "fuse.js": "^7.3.0",
    "js-sha256": "^0.11.1",
    "json-ptr": "^3.1.1",
    "match-json": "^1.3.7",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@ava/typescript": "^7.0.0",
    "@biomejs/biome": "^2.4.15",
    "@tsconfig/node22": "^22.0.5",
    "@types/convict": "^6.1.6",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.19.19",
    "@yarnpkg/sdks": "^3.2.3",
    "ava": "8.0.1",
    "c8": "^11.0.0",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "@oada/lib-prom": "^4.0.1",
    "cross-spawn": "^7.0.5",
    "jsonpath-plus": "^10.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "packageManager": "yarn@4.15.0",
  "volta": {
    "node": "22.9.0"
  }
}
